# ===================================
# CAFE POS - Environment Configuration
# ===================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===============
# Database
# ===============
# Format: mysql://[username]:[password]@[host]:[port]/[database]
DATABASE_URL="mysql://root:password@localhost:3306/cafepos_db"

# ===============
# Security
# ===============
# Generate a strong secret key for JWT tokens
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate-a-strong-secret-key-here-min-32-characters"
JWT_EXPIRY=8h

# ===============
# Server Configuration
# ===============
PORT=5001
NODE_ENV=development
# ALLOWED_ORIGINS=http://localhost:3000   # comma-separated if multiple

# ===============
# Frontend Configuration
# ===============
FRONTEND_URL=http://localhost:3000

# ===============
# SSL (Optional — omit for plain HTTP in dev)
# ===============
# SSL_KEY_PATH=/path/to/privkey.pem
# SSL_CERT_PATH=/path/to/fullchain.pem

# ===============
# Restaurant / Business
# ===============
RESTAURANT_NAME="Cafe POS"
RESTAURANT_ADDRESS="123 Restaurant Street, City"
RESTAURANT_PHONE="+91 98765 43210"
RESTAURANT_GSTIN=
TAX_RATE=0.05
# TAX_LABEL=GST 5%                       # auto-generated from TAX_RATE if omitted
CURRENCY_CODE=INR
CURRENCY_SYMBOL=₹
CURRENCY_LOCALE=en-IN

# ===============
# Inventory Defaults
# ===============
DEFAULT_MIN_STOCK=10
LOW_STOCK_THRESHOLD=10
DEFAULT_PACKAGING_FEE=10

# ===============
# Database Seed (Optional)
# ===============
# SEED_OWNER_EMAIL=admin@cafe.com
# SEED_OWNER_PASSWORD=changeme

# ===============
# Zomato Integration (Optional)
# ===============
ZOMATO_API_KEY=your_zomato_api_key
ZOMATO_RESTAURANT_ID=your_restaurant_id
ZOMATO_WEBHOOK_SECRET=your_webhook_secret
ZOMATO_API_BASE_URL=https://api.zomato.com/v3
ZOMATO_SANDBOX_MODE=true

# ===============
# Swiggy Integration (Optional)
# ===============
SWIGGY_API_KEY=your_swiggy_api_key
SWIGGY_RESTAURANT_ID=your_restaurant_id
SWIGGY_WEBHOOK_SECRET=your_webhook_secret
SWIGGY_API_BASE_URL=https://partner-ondemand-api.swiggy.com
SWIGGY_SANDBOX_MODE=true

# ===============
# Database Logging (Development Only)
# ===============
DEBUG=false
# Set to "query" to see SQL queries in development

# ===============
# End-of-Day Report
# ===============
# Master switch and send time (24h HH:MM, server local time)
EOD_ENABLED=true
EOD_SEND_TIME=22:00

# Email via SMTP  (Gmail example — use an App Password, not your real password)
EOD_EMAIL_ENABLED=true
EOD_EMAIL_TO=pranotivarpe17@gmail.com          
EOD_SMTP_HOST=smtp.gmail.com
EOD_SMTP_PORT=587
EOD_SMTP_USER=pranoti17501@gmail.com
EOD_SMTP_PASS=ipihvefyuihswtuq  
EOD_SMTP_FROM=Cafe POS <pranoti17501@gmail.com>

# WhatsApp via Twilio (free sandbox at twilio.com/try-twilio)
EOD_WHATSAPP_ENABLED=false
EOD_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EOD_TWILIO_AUTH_TOKEN=your_auth_token_here
EOD_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number
EOD_WHATSAPP_TO=whatsapp:+919876543210           # owner's WhatsApp number
