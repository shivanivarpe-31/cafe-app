# Environment Configuration Template
# Copy this to .env and fill in your actual values

# ==========================================
# APPLICATION CORE
# ==========================================

# Node environment: development, staging, production
NODE_ENV=development

# Application port
PORT=5001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# DATABASE
# ==========================================

# Database URL (PostgreSQL/MySQL)
# PostgreSQL: postgresql://user:password@localhost:5432/database
# MySQL: mysql://user:password@localhost:3306/database
DATABASE_URL=mysql://root:password@localhost:3306/cafe_pos

# ==========================================
# AUTHENTICATION
# ==========================================

# JWT Secret (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry (in hours)
JWT_EXPIRES_IN=24

# ==========================================
# SWIGGY INTEGRATION
# ==========================================

# Swiggy API Configuration
SWIGGY_API_KEY=your_swiggy_api_key
SWIGGY_PARTNER_ID=your_swiggy_partner_id
SWIGGY_API_BASE_URL=https://partner-api.swiggy.com/v1

# Swiggy Webhook Secret (from Swiggy Dashboard)
SWIGGY_WEBHOOK_SECRET=your_swiggy_webhook_secret

# Swiggy Mode: 'production' for real API, 'sandbox' for testing
# Leave empty to use sandbox in development
SWIGGY_SANDBOX_MODE=true

# ==========================================
# ZOMATO INTEGRATION
# ==========================================

# Zomato API Configuration
ZOMATO_API_KEY=your_zomato_api_key
ZOMATO_RESTAURANT_ID=your_zomato_restaurant_id
ZOMATO_API_BASE_URL=https://api.zomato.com/v3

# Zomato Webhook Secret (from Zomato Dashboard)
ZOMATO_WEBHOOK_SECRET=your_zomato_webhook_secret

# Zomato Mode: 'production' for real API, 'sandbox' for testing
# Leave empty to use sandbox in development
ZOMATO_SANDBOX_MODE=true

# ==========================================
# DELIVERY CONFIGURATION
# ==========================================

# Default delivery fees and charges
DEFAULT_DELIVERY_FEE=50
DEFAULT_PACKAGING_FEE=10
DEFAULT_TAX_PERCENTAGE=5

# ==========================================
# LOGGING & MONITORING
# ==========================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log to file (true/false)
LOG_TO_FILE=true

# Log file path
LOG_FILE_PATH=./logs/app.log

# ==========================================
# WEBHOOK RETRY CONFIGURATION
# ==========================================

# Maximum retry attempts for failed webhooks
WEBHOOK_MAX_RETRIES=5

# Webhook retry interval (in minutes)
WEBHOOK_RETRY_INTERVAL=1

# ==========================================
# RATE LIMITING (Production Only)
# ==========================================

# API rate limit: requests per 15 minutes (disabled in development)
API_RATE_LIMIT=100

# Login rate limit: attempts per 15 minutes
LOGIN_RATE_LIMIT=5

# Order creation rate limit: orders per 5 minutes
ORDER_RATE_LIMIT=20

# Payment rate limit: attempts per hour
PAYMENT_RATE_LIMIT=30

# ==========================================
# FEATURES & FLAGS
# ==========================================

# Enable platform integrations
ENABLE_SWIGGY=true
ENABLE_ZOMATO=true

# Enable order simulation (for testing)
ENABLE_ORDER_SIMULATION=true

# Enable webhook retry queue processing
ENABLE_WEBHOOK_RETRY_QUEUE=true

# ==========================================
# SECURITY
# ==========================================

# Enable HTTPS only cookies
SECURE_COOKIES=false

# CORS credentials
CORS_CREDENTIALS=true

# ==========================================
# NOTIFICATION (Optional)
# ==========================================

# Email service configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMS service configuration (Twilio, AWS SNS, etc.)
SMS_SERVICE=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# THIRD PARTY SERVICES (Optional)
# ==========================================

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_KEY=your_analytics_key

# Error tracking (Sentry, Rollbar, etc.)
ERROR_TRACKING_ENABLED=false
SENTRY_DSN=https://your_sentry_dsn

# ==========================================
# DEVELOPMENT & TESTING
# ==========================================

# Development debug mode
DEBUG=false

# Seed database on startup
SEED_DATABASE=false

# Enable mock data
USE_MOCK_DATA=true
